<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Space Insurance Premium Estimator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .selected-card {
            border-color: #3b82f6 !important;
            background-color: #eff6ff !important;
            box-shadow: 0 0 0 2px #3b82f6;
        }
        .vehicle-img {
            height: 120px;
            object-fit: cover;
            width: 100%;
            border-radius: 0.375rem 0.375rem 0 0;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans p-6">

    <div class="max-w-6xl mx-auto">
        <header class="mb-8 border-b pb-4">
            <h1 class="text-3xl font-bold text-slate-900">Spacecraft Insurance Estimator</h1>
            <p class="text-slate-600 mt-2">Comprehensive Burn-on-Line & Premium Calculator for Space Operations</p>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="bg-white p-6 rounded-lg shadow-sm border border-slate-200 col-span-1">
                <h2 class="text-xl font-semibold mb-4 text-slate-800">Mission Parameters</h2>
                
                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Total Insured Value ($ Millions)</label>
                    <input type="number" id="insuredValue" value="50" min="1" class="w-full border-slate-300 rounded-md shadow-sm border p-2 focus:ring-blue-500 focus:border-blue-500">
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Target Orbit</label>
                    <select id="orbitSelect" class="w-full border-slate-300 rounded-md shadow-sm border p-2 bg-white">
                        <option value="1.0">Low Earth Orbit (LEO) - Baseline</option>
                        <option value="1.05">Sun-Synchronous Orbit (SSO) - +5% Risk</option>
                        <option value="1.15">Medium Earth Orbit (MEO) - +15% Risk</option>
                        <option value="1.25">Geostationary Transfer (GTO/GEO) - +25% Risk</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Spacecraft Tech Heritage</label>
                    <select id="heritageSelect" class="w-full border-slate-300 rounded-md shadow-sm border p-2 bg-white">
                        <option value="0.9">Flight Proven (>5 identical buses) - 10% Discount</option>
                        <option value="1.0" selected>Standard Heritage (1-4 flights) - Baseline</option>
                        <option value="1.3">Novel Technology (First Flight) - +30% Risk</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-medium text-slate-700 mb-1">Market Capacity Environment</label>
                    <select id="marketSelect" class="w-full border-slate-300 rounded-md shadow-sm border p-2 bg-white">
                        <option value="0">Soft Market (High Capacity / Lower Rates)</option>
                        <option value="1.5" selected>Standard Market (+1.5% Margin)</option>
                        <option value="3.5">Hard Market (Constrained Capacity / +3.5% Margin)</option>
                    </select>
                </div>
            </div>

            <div class="col-span-1 lg:col-span-1 space-y-6">
                <div class="bg-white p-4 rounded-lg shadow-sm border border-slate-200">
                    <h2 class="text-lg font-semibold mb-3 text-slate-800">1. Select Launch Vehicle</h2>
                    <div class="grid grid-cols-2 gap-3" id="lv-container">
                        </div>
                </div>

                <div class="bg-white p-4 rounded-lg shadow-sm border border-slate-200">
                    <h2 class="text-lg font-semibold mb-3 text-slate-800">2. Select Orbital Tug (OTV)</h2>
                    <p class="text-xs text-slate-500 mb-3">OTVs introduce secondary deployment risk.</p>
                    <div class="grid grid-cols-2 gap-3" id="otv-container">
                        </div>
                </div>
            </div>

            <div class="bg-slate-900 text-white p-6 rounded-lg shadow-lg col-span-1 flex flex-col justify-between">
                <div>
                    <h2 class="text-xl font-semibold mb-6 text-blue-300 border-b border-slate-700 pb-2">Premium Breakdown</h2>
                    
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-slate-400">System Success Prob:</span>
                        <span id="out-pos" class="font-mono text-lg">--%</span>
                    </div>
                    
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-slate-400">Technical Burn Rate:</span>
                        <span id="out-tech-rate" class="font-mono text-lg text-yellow-400">--%</span>
                    </div>

                    <div class="flex justify-between items-center mb-6">
                        <span class="text-slate-400">Final Commercial Rate:</span>
                        <span id="out-final-rate" class="font-mono text-xl text-blue-400 font-bold">--%</span>
                    </div>

                    <hr class="border-slate-700 mb-6">

                    <div class="mb-4">
                        <p class="text-slate-400 text-sm mb-1">Total Insured Value</p>
                        <p id="out-tiv" class="text-2xl font-mono">$0.00 M</p>
                    </div>

                    <div class="mb-2">
                        <p class="text-slate-400 text-sm mb-1">Estimated Total Premium</p>
                        <p id="out-premium" class="text-4xl font-mono text-emerald-400 font-bold">$0.00</p>
                    </div>
                </div>
                
                <div class="mt-8 bg-slate-800 p-4 rounded text-sm text-slate-300">
                    <p><strong>Note:</strong> Commercial Rate includes base failure probability (Burn-on-Line), orbit/tech risk multipliers, MGA margins, and an assumed 15% broker commission.</p>
                </div>
            </div>

        </div>
    </div>

    <script>
        // Database of Vehicles
        const launchVehicles = [
            { id: 'f9', name: 'Falcon 9', reliability: 0.992, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/c/c8/Falcon_9_carrying_the_Crew_Dragon_in-flight.jpg/320px-Falcon_9_carrying_the_Crew_Dragon_in-flight.jpg' },
            { id: 'starship', name: 'Starship', reliability: 0.850, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/30/Starship_Flight_3_launch.jpg/320px-Starship_Flight_3_launch.jpg' },
            { id: 'electron', name: 'Electron', reliability: 0.920, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/Electron_launch_vehicle_%28cropped%29.jpg/320px-Electron_launch_vehicle_%28cropped%29.jpg' },
            { id: 'ariane', name: 'Ariane 6', reliability: 0.900, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/2/25/Ariane_6_First_Flight_VA262_%2853846617015%29_%28cropped%29.jpg/320px-Ariane_6_First_Flight_VA262_%2853846617015%29_%28cropped%29.jpg' }
        ];

        const orbitalTugs = [
            { id: 'none', name: 'Direct Deploy', reliability: 1.0, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/e/e8/AS-204_spacecraft_in_orbit_%28artist%27s_concept%29.jpg/320px-AS-204_spacecraft_in_orbit_%28artist%27s_concept%29.jpg' },
            { id: 'sherpa', name: 'Spaceflight Sherpa', reliability: 0.96, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/b/b3/Sherpa_FX_satellite_dispenser_%2850868114092%29.jpg/320px-Sherpa_FX_satellite_dispenser_%2850868114092%29.jpg' },
            { id: 'vigoride', name: 'Momentus Vigoride', reliability: 0.90, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/a/a2/Vigoride-5_orbital_transfer_vehicle.png/320px-Vigoride-5_orbital_transfer_vehicle.png' },
            { id: 'ion', name: 'D-Orbit ION', reliability: 0.97, img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/ION_Satellite_Carrier.jpg/320px-ION_Satellite_Carrier.jpg' }
        ];

        let selectedLV = launchVehicles[0];
        let selectedOTV = orbitalTugs[0];

        // UI Initialization
        function initCards() {
            const lvContainer = document.getElementById('lv-container');
            const otvContainer = document.getElementById('otv-container');

            launchVehicles.forEach(lv => {
                const div = document.createElement('div');
                div.className = `border border-slate-200 rounded-lg cursor-pointer hover:shadow-md transition bg-white overflow-hidden ${lv.id === selectedLV.id ? 'selected-card' : ''}`;
                div.onclick = () => { selectedLV = lv; updateUI(); calculatePremium(); };
                div.innerHTML = `
                    <img src="${lv.img}" alt="${lv.name}" class="vehicle-img">
                    <div class="p-2 text-center">
                        <p class="font-bold text-sm">${lv.name}</p>
                        <p class="text-xs text-slate-500">Rel: ${(lv.reliability * 100).toFixed(1)}%</p>
                    </div>
                `;
                lvContainer.appendChild(div);
            });

            orbitalTugs.forEach(otv => {
                const div = document.createElement('div');
                div.className = `border border-slate-200 rounded-lg cursor-pointer hover:shadow-md transition bg-white overflow-hidden ${otv.id === selectedOTV.id ? 'selected-card' : ''}`;
                div.onclick = () => { selectedOTV = otv; updateUI(); calculatePremium(); };
                div.innerHTML = `
                    <img src="${otv.img}" alt="${otv.name}" class="vehicle-img">
                    <div class="p-2 text-center">
                        <p class="font-bold text-sm">${otv.name}</p>
                        <p class="text-xs text-slate-500">${otv.id === 'none' ? 'N/A' : 'Rel: ' + (otv.reliability * 100).toFixed(1) + '%'}</p>
                    </div>
                `;
                otvContainer.appendChild(div);
            });
        }

        function updateUI() {
            // Update LV Cards
            const lvCards = document.getElementById('lv-container').children;
            launchVehicles.forEach((lv, index) => {
                lvCards[index].className = `border border-slate-200 rounded-lg cursor-pointer hover:shadow-md transition bg-white overflow-hidden ${lv.id === selectedLV.id ? 'selected-card' : ''}`;
            });

            // Update OTV Cards
            const otvCards = document.getElementById('otv-container').children;
            orbitalTugs.forEach((otv, index) => {
                otvCards[index].className = `border border-slate-200 rounded-lg cursor-pointer hover:shadow-md transition bg-white overflow-hidden ${otv.id === selectedOTV.id ? 'selected-card' : ''}`;
            });
        }

        function calculatePremium() {
            const tiv = parseFloat(document.getElementById('insuredValue').value) || 0;
            const orbitMultiplier = parseFloat(document.getElementById('orbitSelect').value);
            const heritageMultiplier = parseFloat(document.getElementById('heritageSelect').value);
            const marketMargin = parseFloat(document.getElementById('marketSelect').value);

            // Math: Compound Probability of Success
            const systemPoS = selectedLV.reliability * selectedOTV.reliability;
            const baseBurnRate = (1 - systemPoS) * 100; // Convert to percentage

            // Technical Rate (Risk adjusted for Orbit and Tech Maturity)
            const technicalRate = baseBurnRate * orbitMultiplier * heritageMultiplier;

            // Commercial Rate (Adding MGA Margin + ~15% Brokerage load standard in market)
            const brokerLoad = 1.15;
            const commercialRate = (technicalRate * brokerLoad) + marketMargin;

            // Total Cost
            const totalPremium = tiv * (commercialRate / 100);

            // Update DOM
            document.getElementById('out-pos').innerText = (systemPoS * 100).toFixed(2) + '%';
            document.getElementById('out-tech-rate').innerText = technicalRate.toFixed(2) + '%';
            document.getElementById('out-final-rate').innerText = commercialRate.toFixed(2) + '%';
            document.getElementById('out-tiv').innerText = `$${tiv.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})} M`;
            
            // Format Premium output
            if(totalPremium >= 1) {
                document.getElementById('out-premium').innerText = `$${totalPremium.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})} M`;
            } else {
                document.getElementById('out-premium').innerText = `$${(totalPremium * 1000000).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})}`;
            }
        }

        // Event Listeners
        document.querySelectorAll('input, select').forEach(el => {
            el.addEventListener('input', calculatePremium);
        });

        // Init
        initCards();
        calculatePremium();

    </script>
</body>
</html>
